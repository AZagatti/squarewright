+            _, peak = tracemalloc.get_traced_memory()
+        finally:
+            tracemalloc.stop()
+        # We should never have allocated anywhere near the full payload.
+        # Give plenty of headroom for compression bookkeeping.
+        self.assertLess(peak, len(payload) // 4)
