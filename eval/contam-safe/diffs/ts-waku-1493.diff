+        } else {
+          // skip during scan build
+          if (this.environment.config.build.write) {
+            const config = this.environment.getTopLevelConfig();
+            const file = path.join(
+              config.environments.client!.build.outDir,
+              'index.html',
+            );
+            html = fs.readFileSync(file, 'utf-8');
